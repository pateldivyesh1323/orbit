MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=orbit

# Generate: openssl rand -hex 32
JWT_SECRET_KEY=random-secret-key

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/api/webhook/whatsapp
TWILIO_VALIDATE_SIGNATURES=false

ENABLE_DEV_ROUTES=true

# Fernet key for encrypting integration credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Must be 32 url-safe base64-encoded bytes. Do NOT rotate after storing keys — existing ciphertext becomes unreadable.
INTEGRATION_ENCRYPTION_KEY=

# Generate: openssl rand -hex 32
CRON_SECRET=

# Frontend origin used for OAuth post-callback redirects.
FRONTEND_URL=http://localhost:3000

# Google Calendar OAuth — see docs/google_calendar_setup.md
# 1. Go to https://console.cloud.google.com/, create a project.
# 2. APIs & Services → Library → enable "Google Calendar API".
# 3. OAuth consent screen → External, add yourself as a Test user.
# 4. Credentials → Create OAuth client ID → Web application.
#    Authorized redirect URI: http://localhost:8000/api/integrations/oauth/google_calendar/callback
# 5. Copy Client ID and Client Secret here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/oauth/google_calendar/callback
